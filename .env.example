# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/pixeleco

# ── Auth ──────────────────────────────────────
NEXTAUTH_SECRET=generate-a-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── Cloudflare R2 ─────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=fotiqo-photos
R2_PUBLIC_URL=

# ── Cloudinary ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_WATERMARK_PUBLIC_ID=fotiqo_watermark

# ── Stripe ─────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TERMINAL_LOCATION_ID=

# ── WhatsApp Cloud API ─────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ── Email (Resend) ─────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=noreply@fotiqo.com

# ── AI ─────────────────────────────────────────
OPENAI_API_KEY=
AI_CULLING_ENDPOINT=

# ── Face Recognition (Face++ free tier: 1,000 calls/day) ──
# Sign up at https://console.faceplusplus.com
FACEPP_API_KEY=
FACEPP_API_SECRET=

# ── App ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
