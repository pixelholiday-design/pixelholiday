# PixelHoliday — production environment template
# Copy values into Vercel project settings → Environment Variables.
# Each section is annotated CRITICAL (app won't function) or OPTIONAL (graceful 503 mock).

# ── DATABASE — CRITICAL ─────────────────────────────────────────────────────
# Neon Postgres connection string. Use the "pooled" connection for serverless.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── AUTH — CRITICAL ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_32_BYTE_RANDOM"
NEXTAUTH_URL="https://your-domain.com"

# ── APP — CRITICAL ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ── CLOUDFLARE R2 — CRITICAL for uploads ────────────────────────────────────
# Get from Cloudflare dashboard → R2 → Manage R2 API tokens.
# When unset, presigned URLs return a mock and uploads no-op gracefully.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="pixelholiday-photos"
# Public-read base for the bucket (e.g. https://photos.your-domain.com)
R2_PUBLIC_URL=""

# ── CLOUDINARY — CRITICAL for watermarking + ZIP downloads ──────────────────
# When unset, gallery shows R2 URLs unwatermarked-via-fetch and /download returns 503.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Asset name (not full URL) of your uploaded watermark PNG, e.g. "pixelholiday_watermark"
CLOUDINARY_WATERMARK_PUBLIC_ID="pixelholiday_watermark"
# Same as above but exposed to the client (URL builder runs both server and client).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_WATERMARK_PUBLIC_ID="pixelholiday_watermark"

# ── STRIPE — CRITICAL for payments ──────────────────────────────────────────
# START IN TEST MODE. Only switch to live keys after a full test-mode dry run.
# When unset, /api/checkout returns 503 — no fake payments are processed.
STRIPE_SECRET_KEY="sk_test_..."
# Set after creating the webhook endpoint in Stripe dashboard → Developers → Webhooks.
# Endpoint URL: https://your-domain.com/api/webhooks/stripe
# Events to send: checkout.session.completed
STRIPE_WEBHOOK_SECRET="whsec_..."
# Optional — Stripe Terminal location ID for in-person card payments at the kiosk.
STRIPE_TERMINAL_LOCATION_ID=""

# ── EMAIL (Resend) — OPTIONAL ───────────────────────────────────────────────
# Required if you want delivery emails on payment. Falls back to console log otherwise.
RESEND_API_KEY=""
# Must be a verified domain in Resend.
FROM_EMAIL="hello@your-domain.com"

# ── WHATSAPP CLOUD API — OPTIONAL ───────────────────────────────────────────
# When unset, WhatsApp messages log to the console instead of sending.
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN=""
