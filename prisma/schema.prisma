// ── SUPPORT CHAT ─────────────────────────────
model SupportChat {
  id               String            @id @default(cuid())
  userId           String?
  visitorEmail     String?
  visitorName      String?
  sessionId        String
  status           SupportChatStatus @default(ACTIVE)
  channel          String            @default("WIDGET")
  page             String?
  product          String?
  userRole         String?
  csatScore        Int?
  csatFeedback     String?
  csatRatedAt      DateTime?
  resolvedAt       DateTime?
  resolvedBy       String?
  aiHandled        Boolean           @default(false)
  escalatedToHuman Boolean           @default(false)
  messages         SupportMessage[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

