  fulfillmentType        String           @default("AUTO") // AUTO, MANUAL, DIGITAL
  labProductId           String? // Prodigi/Printful/WHCC SKU
  labName                String? // PRODIGI, PRINTFUL, WHCC, LOCAL
  mockupUrl              String?
  roomPreviewUrl         String? // Room scene mockup for wall art
  hasRoomPreview         Boolean          @default(false)
  hasPersonalizedPreview Boolean          @default(true)
  minPhotos              Int              @default(1)
  maxPhotos              Int?
  isDigital              Boolean          @default(false)
  isActive               Boolean          @default(true)
  isFeatured             Boolean          @default(false)
  comingSoon             Boolean          @default(false)
  sortOrder              Int              @default(0)
  weight                 Float? // grams
  shippingClass          String? // STANDARD, OVERSIZED, FRAGILE
  turnaround             String? // "3-5 business days"
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  orderItems             ShopOrderItem[]
  priceSheetItems        PriceSheetItem[]

  @@index([category])
  @@index([isActive, isFeatured])
}

// Price sheets for SaaS photographers — custom markup per product
model PriceSheet {
  id                String           @id @default(cuid())
  organizationId    String
  organization      Organization     @relation(fields: [organizationId], references: [id])
  name              String // "Wedding Price Sheet"
  isDefault         Boolean          @default(false)
  bulkMarkupPercent Float? // e.g. 80 = 80% markup on all
  items             PriceSheetItem[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([organizationId])
}

model PriceSheetItem {
  id            String      @id @default(cuid())
  priceSheetId  String
  priceSheet    PriceSheet  @relation(fields: [priceSheetId], references: [id])
  shopProductId String
  shopProduct   ShopProduct @relation(fields: [shopProductId], references: [id])
  isEnabled     Boolean     @default(true)
  markupPercent Float?
  customPrice   Float?

  @@unique([priceSheetId, shopProductId])
  @@index([priceSheetId])
}

model PrintLabPartner {
  id            String   @id @default(cuid())
  name          String
  type          String // PRODIGI_API, WHCC_API, ZNO_API, MANUAL, LOCAL
  apiBaseUrl    String?
  apiKey        String?
  isActive      Boolean  @default(true)
  isDefault     Boolean  @default(false)
  markupPercent Float    @default(50)
  shippingRates String?  @db.Text // JSON
  capabilities  String?  @db.Text // JSON: ["prints","canvas","books","cards"]
  createdAt     DateTime @default(now())
}

model ShopOrder {
  id               String          @id @default(cuid())
  customerId       String
  customer         Customer        @relation("ShopOrders", fields: [customerId], references: [id])
  galleryId        String?
  status           String          @default("PENDING") // PENDING, PAID, PROCESSING, SHIPPED, DELIVERED, CANCELLED, REFUNDED
  items            ShopOrderItem[]
  shippingName     String?
  shippingAddress  String?
  shippingCity     String?
  shippingCountry  String?
  shippingPostal   String?
  shippingPhone    String?
  shippingMethod   String? // STANDARD, EXPRESS
  shippingCost     Float           @default(0)
  subtotal         Float
  discount         Float           @default(0)
  couponCode       String?
  tax              Float           @default(0)
  total            Float
  stripeSessionId  String?
  labOrderId       String?
  labName          String?
  trackingNumber   String?
  trackingUrl      String?
  fotiqoCommission Float           @default(0) // 2% sales + 50% shop profit
  notes            String? // Internal admin notes
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
}

model ShopOrderItem {
  id            String      @id @default(cuid())
  shopOrderId   String
  shopOrder     ShopOrder   @relation(fields: [shopOrderId], references: [id])
  productId     String
  product       ShopProduct @relation(fields: [productId], references: [id])
  photoId       String?
  size          String?
  option        String?
  quantity      Int         @default(1)
  unitPrice     Float
  totalPrice    Float
  bookPages     Int?
  bookCoverType String?
  bookPhotoIds  String?     @db.Text // JSON array
  status        String      @default("PENDING")
  labItemId     String?
  createdAt     DateTime    @default(now())

  @@index([shopOrderId])
}

// ── PHOTOGRAPHER PROFILE & WEBSITE BUILDER ────
model PhotographerProfile {
  id                   String                     @id @default(cuid())
  userId               String                     @unique
  user                 User                       @relation("UserPhotographerProfile", fields: [userId], references: [id])
  username             String                     @unique // slug for /p/[username]
  businessName         String?
  tagline              String?
  bio                  String?                    @db.Text
  profilePhotoUrl      String?
  coverPhotoUrl        String?
  specialties          String[]                   @default([]) // ["wedding","portrait","landscape","event","resort","commercial"]
  experience           String? // "1-3 years", "3-5 years", "5-10 years", "10+ years"
  equipment            String[]                   @default([]) // ["Canon R5","Sony A7IV"]
  languages            String[]                   @default([]) // ["English","French","Arabic"]
  city                 String?
  country              String?
  latitude             Float?
  longitude            Float?
  serviceAreaKm        Int?
  priceRange           String? // "€50-€100/hour"
  hourlyRate           Float?
  totalReviews         Int                        @default(0)
  averageRating        Float                      @default(0)
  completedSessions    Int                        @default(0)
  responseTime         String? // e.g. "Within 1 hour"
  socialInstagram      String?
  socialFacebook       String?
  socialWebsite        String?
  socialTiktok         String?
  instagramAccessToken String?
  instagramUserId      String?
  isPublicProfile      Boolean                    @default(true)
  // Website builder settings
  websiteTheme         String                     @default("minimal") // minimal, bold, classic, modern, dark, light
  primaryColor         String                     @default("#0EA5A5")
  fontChoice           String                     @default("inter") // inter, playfair, montserrat, lora, raleway
  logoUrl              String?
  sections             String?                    @db.Text // JSON array of section config [{type,order,visible}]
  customDomain         String?                    @unique
  seoTitle             String?
  seoDescription       String?
  seoImage             String?
  // WhatsApp floating button
  whatsappEnabled      Boolean                    @default(false)
  whatsappNumber       String?
  whatsappMessage      String?
  whatsappPosition     String                     @default("bottom-right") // bottom-right, bottom-left
  // Portfolio galleries (which galleries to feature)
  featuredGalleryIds   String[]                   @default([])
  // Services offered
  services             PhotographerService[]
  // Testimonials
  testimonials         PhotographerTestimonial[]
  // Inquiries
  inquiries            PhotographerInquiry[]
  reviews              PhotographerReview[]
  availability         PhotographerAvailability[]
  bookings             MarketplaceBooking[]
  portfolioPhotos      PortfolioPhoto[]
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  @@index([username])
  @@index([isPublicProfile])
  @@index([city, country])
}

model PhotographerService {
  id          String              @id @default(cuid())
  profileId   String
  profile     PhotographerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  description String?             @db.Text
  startingAt  Float? // Starting price
  currency    String              @default("EUR")
  duration    String? // "2 hours", "Full day"
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())

  @@index([profileId])
}

model PhotographerTestimonial {
  id         String              @id @default(cuid())
  profileId  String
  profile    PhotographerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  clientName String
  content    String              @db.Text
  rating     Int                 @default(5) // 1-5
  eventType  String? // "Wedding", "Portrait"
  date       DateTime?
  isVisible  Boolean             @default(true)
  sortOrder  Int                 @default(0)
  createdAt  DateTime            @default(now())

  @@index([profileId])
}

model PhotographerInquiry {
  id        String              @id @default(cuid())
  profileId String
  profile   PhotographerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  eventType String?
  eventDate DateTime?
  message   String              @db.Text
  budget    String?
  status    InquiryStatus       @default(NEW)
  createdAt DateTime            @default(now())

  @@index([profileId])
  @@index([status])
}

enum InquiryStatus {
  NEW
  CONTACTED
  BOOKED
  DECLINED
}

// ── PHOTOGRAPHER MARKETPLACE ──────────────────
model PhotographerReview {
  id             String              @id @default(cuid())
  profileId      String
  profile        PhotographerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  photographerId String
  photographer   User                @relation("PhotographerReviews", fields: [photographerId], references: [id])
  bookingId      String?             @unique
  booking        MarketplaceBooking? @relation(fields: [bookingId], references: [id])
  customerName   String
  customerEmail  String?
  rating         Int // 1-5 stars
  title          String?
  comment        String              @db.Text
  photoUrls      String[]            @default([]) // Photos from the session as proof
  response       String?             @db.Text // Photographer's reply
  respondedAt    DateTime?
  isVerified     Boolean             @default(false) // Booked through platform
  isPublic       Boolean             @default(true)
  createdAt      DateTime            @default(now())

  @@index([profileId])
  @@index([photographerId])
  @@index([rating])
}

model PhotographerAvailability {
  id          String               @id @default(cuid())
  userId      String
  user        User                 @relation("PhotographerAvailabilities", fields: [userId], references: [id])
  profileId   String?
  profile     PhotographerProfile? @relation(fields: [profileId], references: [id])
  date        DateTime             @db.Date
  startTime   String // "09:00"
  endTime     String // "17:00"
  isAvailable Boolean              @default(true)
  isRecurring Boolean              @default(false)
  dayOfWeek   Int? // 0=Sun, 1=Mon ... 6=Sat (for recurring)
  notes       String?
  createdAt   DateTime             @default(now())

  @@unique([userId, date])
  @@index([userId, isAvailable])
  @@index([date])
}

model MarketplaceBooking {
  id                 String                   @id @default(cuid())
  profileId          String
  profile            PhotographerProfile      @relation(fields: [profileId], references: [id])
  photographerId     String
  photographer       User                     @relation("PhotographerMarketplaceBookings", fields: [photographerId], references: [id])
  // Customer info
  customerName       String
  customerEmail      String
  customerPhone      String?
  // Session details
  serviceId          String?
  sessionType        String // "Portrait Session", "Wedding", etc.
  sessionDate        DateTime
  sessionStartTime   String // "10:00"
  sessionDuration    Int // minutes
  sessionLocation    String?
  occasion           String?
  groupSize          Int                      @default(1)
  specialRequests    String?                  @db.Text
  // Pricing
  totalPrice         Float
  depositAmount      Float?
  currency           String                   @default("EUR")
  // Platform commission tracking
  platformFeeRate    Float                    @default(0.10) // 10% marketplace fee
  platformFee        Float? // Calculated: totalPrice * platformFeeRate
  photographerPayout Float? // totalPrice - platformFee - stripeFee
  stripeFee          Float? // Stripe processing fee on this booking
  // Payment
  stripeSessionId    String?
  stripePaymentId    String?
  isPaid             Boolean                  @default(false)
  paidAt             DateTime?
  payoutStatus       PayoutStatus             @default(PENDING)
  payoutAt           DateTime? // When photographer was paid out
  escrowReleasedAt   DateTime? // When escrow hold was released
  // Status
  status             MarketplaceBookingStatus @default(PENDING)
  // Communication
  photographerNotes  String?                  @db.Text
  // Review
  review             PhotographerReview?
  reviewRequestSent  Boolean                  @default(false)
  reviewRequestedAt  DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([profileId])
  @@index([photographerId])
  @@index([status])
  @@index([sessionDate])
}

enum MarketplaceBookingStatus {
  PENDING
  CONFIRMED
  DEPOSIT_PAID
  FULLY_PAID
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PayoutStatus {
  PENDING // Funds held in escrow
  HELD // Session completed, 48-hour hold
  RELEASED // Funds released to photographer
  PAID // Stripe transfer completed
  CANCELLED // Booking cancelled, refunded
}

model PortfolioPhoto {
  id           String              @id @default(cuid())
  profileId    String
  profile      PhotographerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  url          String
  thumbnailUrl String?
  caption      String?
  category     String? // "wedding", "portrait", etc.
  sortOrder    Int                 @default(0)
  isFeatured   Boolean             @default(false)
  createdAt    DateTime            @default(now())

  @@index([profileId])
  @@index([category])
}

// ── PHOTO PACKAGES (Bokun-style instant booking) ──

enum PackageCategory {
  FAMILY
  COUPLE
  SOLO
  GROUP
  KIDS
  EVENT
  SPECIALTY
}

enum PackageBookingStatus {
  PENDING
  CONFIRMED
  PAID
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  REFUNDED
}

model PhotoPackage {
  id                 String           @id @default(cuid())
  name               String
  slug               String           @unique
  description        String           @db.Text
  shortDescription   String?
  category           PackageCategory
  sessionType        String           @default("MIXED") // PORTRAIT, ACTION, CANDID, MIXED
  duration           Int // minutes
  deliveredPhotos    Int // minimum guaranteed photos
  price              Float // base price in currency
  depositAmount      Float? // if null, full payment upfront
  currency           String           @default("EUR")
  coverImage         String?
  galleryImages      String[]         @default([])
  whatsIncluded      String[]         @default([])
  whatToBring        String[]         @default([])
  cancellationPolicy String?          @db.Text
  maxGroupSize       Int              @default(6)
  minGroupSize       Int              @default(1)
  isActive           Boolean          @default(true)
  isFeatured         Boolean          @default(false)
  sortOrder          Int              @default(0)
  locationId         String?
  location           Location?        @relation(fields: [locationId], references: [id])
  addOns             PackageAddOn[]
  bookings           PackageBooking[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([slug])
  @@index([category])
  @@index([isActive, sortOrder])
}

model PackageAddOn {
  id          String       @id @default(cuid())
  packageId   String
  package     PhotoPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  currency    String       @default("EUR")
  isDefault   Boolean      @default(false)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())

  @@index([packageId])
}

model PackageBooking {
  id                     String               @id @default(cuid())
  confirmationCode       String               @unique
  // Package
  packageId              String
  package                PhotoPackage         @relation(fields: [packageId], references: [id])
  // Photographer (auto-assigned)
  assignedPhotographerId String?
  assignedPhotographer   User?                @relation("PackageBookingPhotographer", fields: [assignedPhotographerId], references: [id])
  // Appointment link
  appointmentId          String?              @unique
  appointment            Appointment?         @relation(fields: [appointmentId], references: [id])
  // Customer
  customerId             String?
  customer               Customer?            @relation(fields: [customerId], references: [id])
  customerName           String
  customerEmail          String
  customerPhone          String?
  // Session details
  sessionDate            DateTime
  sessionStartTime       String // "17:00"
  groupSize              Int                  @default(1)
  specialRequests        String?              @db.Text
  // Pricing
  basePrice              Float
  addOnsTotal            Float                @default(0)
  addOnsSelected         String[]             @default([]) // add-on names for display
  totalPrice             Float
  currency               String               @default("EUR")
  // Platform fees
  platformFeeRate        Float                @default(0.15) // 15% for resort packages
  platformFee            Float?
  photographerPayout     Float?
  stripeFee              Float?
  // Payment
  stripeSessionId        String?
  stripePaymentId        String?
  isPaid                 Boolean              @default(false)
  paidAt                 DateTime?
  // Status
  status                 PackageBookingStatus @default(PENDING)
  // Location
  locationId             String?
  location               Location?            @relation(fields: [locationId], references: [id])
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([status])
  @@index([sessionDate])
  @@index([packageId])
  @@index([confirmationCode])
}

// ── SUGGESTION SYSTEM ────────────────────────
model Suggestion {
  id                 String             @id @default(cuid())
  userId             String?
  customerEmail      String?
  customerName       String?
  userRole           String?
  content            String
  category           SuggestionCategory @default(FEATURE)
  page               String?
  product            String?
  aiEvaluation       String?
  aiSummary          String?
  impactScore        Int?
  feasibility        Int?
  priorityScore      Int?
  isDuplicate        Boolean            @default(false)
  duplicateOf        String?
  status             SuggestionStatus   @default(NEW)
  autoImplemented    Boolean            @default(false)
  implementedAt      DateTime?
  implementationNote String?
  responseToUser     String?
  respondedAt        DateTime?
  upvotes            Int                @default(0)
  locationId         String?
  organizationId     String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([status])
  @@index([category])
  @@index([priorityScore])
}

enum SuggestionCategory {
  FEATURE
  UI_UX
  PRICING
  BUG
  CONTENT
  PERFORMANCE
  SECURITY
  INTEGRATION
  OTHER
}

enum SuggestionStatus {
  NEW
  AI_REVIEWED
  AUTO_APPLIED
  APPROVED
  IN_PROGRESS
  COMPLETED
  DECLINED
  DUPLICATE
}

// ── CONTRACTS & E-SIGNATURES ─────────────────
model Contract {
