// Fotiqo master Prisma schema — see CLAUDE.md Section 1
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── USERS & AUTH ──────────────────────────────
model Organization {
  id                       String              @id @default(cuid())
  name                     String
  slug                     String?             @unique // "tunisphoto" — for /v/[slug] portal URL
  type                     OrgType
  parentOrgId              String?
  parentOrg                Organization?       @relation("FranchiseTree", fields: [parentOrgId], references: [id])
  children                 Organization[]      @relation("FranchiseTree")
  locations                Location[]
  staff                    User[]
  subscriptionTier         SubscriptionTier    @default(STARTER)
  saasCommissionRate       Float               @default(0.02)
  sleepingMoneyShare       Float               @default(0.50)
  // White-label branding
  brandColor               String?
  brandName                String? // "TunisPhoto" — shown on their portal
  brandLogo                String? // logo URL for light backgrounds
  brandLogoDark            String? // logo URL for dark backgrounds
  brandPrimaryColor        String? // e.g. "#FF5733"
  brandSecondaryColor      String?
  brandFavicon             String?
  showPoweredByFotiqo      Boolean             @default(true)
  logoUrl                  String?
  tagline                  String?
  customDomain             String?
  // Company details (for VENUE_COMPANY)
  website                  String?
  phone                    String?
  country                  String?
  city                     String?
  taxId                    String?
  contractStartDate        DateTime?
  contractEndDate          DateTime?
  commissionRate           Float? // negotiated override rate
  // Subscription plan
  plan                     String              @default("STARTER") // STARTER, PRO, STUDIO
  planInterval             String? // MONTHLY, ANNUAL
  planStartedAt            DateTime?
  planExpiresAt            DateTime?
  stripeCustomerId         String?
  stripeSubscriptionId     String?
  stripeConnectAccountId   String?
  stripeConnectStatus      String?
  stripeConnectOnboardedAt DateTime?
  trialStartedAt           DateTime?
  trialEndsAt              DateTime?
  trialExpired             Boolean             @default(false)
  priceSheets              PriceSheet[]
  agentConversations       AgentConversation[] @relation("OrgAgentConversations")
  agentTasks               AgentTask[]         @relation("OrgAgentTasks")
  agentSettings            AgentSettings?      @relation("OrgAgentSettings")
  createdAt                DateTime            @default(now())
}

model User {
  id                   String                     @id @default(cuid())
  name                 String
  email                String                     @unique
  password             String?
  phone                String?
  pin                  String?
  role                 StaffRole
  orgId                String
  org                  Organization               @relation(fields: [orgId], references: [id])
  locationId           String?
  location             Location?                  @relation(fields: [locationId], references: [id])
  isRepeater           Boolean                    @default(false)
  repeaterYears        Int                        @default(0)
  salary               Float?
  rating               Float                      @default(0)
  equipmentAssignments EquipmentAssignment[]
  galleries            Gallery[]                  @relation("PhotographerGalleries")
  appointments         Appointment[]              @relation("AssignedPhotographer")
  commissions          Commission[]
  shifts               Shift[]
  housing              StaffHousing?
  blogPosts            BlogPost[]
  chatMessages         ChatMessage[]
  chatMemberships      ChatMember[]
  xp                   Int                        @default(0)
  level                Int                        @default(1)
  badges               String[]                   @default([])
  streakDays           Int                        @default(0)
  lastActivityAt       DateTime?
  userBadges           UserBadge[]
  xpLogs               XpLog[]
  photoAnalyses        PhotoAnalysis[]            @relation("PhotographerAnalyses")
  skillProfile         PhotographerSkillProfile?  @relation("UserSkillProfile")
  trainingAssignments  TrainingAssignment[]       @relation("UserTrainingAssignments")
  weeklySkillReports   WeeklySkillReport[]        @relation("UserWeeklyReports")
  zoneAssignments      ZoneAssignment[]           @relation("UserZoneAssignments")
  appointmentOutcomes  AppointmentOutcome[]       @relation("UserAppointmentOutcomes")
  photographerProfile  PhotographerProfile?       @relation("UserPhotographerProfile")
  reviews              PhotographerReview[]       @relation("PhotographerReviews")
  availability         PhotographerAvailability[] @relation("PhotographerAvailabilities")
  marketplaceBookings  MarketplaceBooking[]       @relation("PhotographerMarketplaceBookings")
  packageBookings      PackageBooking[]           @relation("PackageBookingPhotographer")
  agentConversations   AgentConversation[]        @relation("UserAgentConversations")
  staffProfile         StaffProfile?              @relation("UserStaffProfile")
  fotiqoEmails         FotiqoEmail[]              @relation("UserFotiqoEmails")
  emailMessages        EmailMessage[]             @relation("UserEmailMessages")
  emailSignature       EmailSignature?            @relation("UserEmailSignature")
  createdAt            DateTime                   @default(now())
}

enum StaffRole {
  CEO
  OPERATIONS_MANAGER
  SUPERVISOR
  PHOTOGRAPHER
  SALES_STAFF
  RECEPTIONIST
  ACADEMY_TRAINEE
}

enum OrgType {
  HEADQUARTERS // Fotiqo admin (Joe)
  FRANCHISE // Legacy franchised operation
  INDEPENDENT // Solo freelance photographer (SaaS)
  STUDIO // Photography studio/team (SaaS)
  VENUE_COMPANY // Photography company at venues (contract partner)
  MARKETPLACE_ONLY // Marketplace-only photographer
}

enum SubscriptionTier {
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

// ── LOCATIONS ─────────────────────────────────
model Location {
  id                 String           @id @default(cuid())
  name               String
  type               LocationType
  orgId              String
  org                Organization     @relation(fields: [orgId], references: [id])
  address            String?
  partnerCommission  Float?
  rentCost           Float?
  qrCodes            QRCode[]
  staff              User[]
  galleries          Gallery[]
  equipment          Equipment[]
  b2bDeliveries      B2BDelivery[]
  chatChannels       ChatChannel[]
  cameras            Camera[]
  kiosks             KioskDevice[]
  cashRegisters      CashRegister[]
  locationType       String           @default("LUXURY")
  targetAOV          Float?
  maxShiftHours      Int              @default(8)
  siestaStart        String?
  siestaEnd          String?
  country            String           @default("Tunisia")
  city               String?
  timezone           String           @default("Africa/Tunis")
  defaultLocale      String           @default("en")
  currency           String           @default("EUR")
  taxRate            Float            @default(0.19)
  rentAmount         Float?
  rentType           String?
  rentPercentage     Float?
  targetDailyRevenue Float?
  targetCaptureRate  Float?
  scheduleType       String           @default("SIESTA")
  morningStart       String?
  morningEnd         String?
  eveningStart       String?
  eveningEnd         String?
  rotationHours      Int?
  commissionType     String           @default("FLAT")
  commissionRate     Float            @default(0.10)
  attendanceBonus    Float            @default(2.0)
  vipCloserBonus     Float            @default(0.05)
  tier1Threshold     Float?
  tier1Rate          Float?
  tier2Threshold     Float?
  tier2Rate          Float?
  tier3Rate          Float?
  supervisorOverride Float?
  partnerName        String?
  partnerContact     String?
  partnerEmail       String?
  partnerPhone       String?
  roomCount          Int?
  occupancyRate      Float?
  contractStartDate  DateTime?
  contractEndDate    DateTime?
  isActive           Boolean          @default(true)
  pricingConfigs     PricingConfig[]
  appointments       Appointment[]
  photoPackages      PhotoPackage[]
  packageBookings    PackageBooking[]
  createdAt          DateTime         @default(now())
}

enum LocationType {
  HOTEL
  WATER_PARK
  ATTRACTION
  SELF_SERVICE
}

// ── CUSTOMERS ─────────────────────────────────
model Customer {
  id                     String           @id @default(cuid())
  name                   String?
  email                  String?
  whatsapp               String?
  roomNumber             String?
  faceVector             Bytes?
  wristbandCode          String?
  nfcTag                 String?
  hasDigitalPass         Boolean          @default(false)
  digitalPassType        DigitalPassType?
  preferredLocale        String?
  detectedLanguage       String? // auto-detected: en, fr, de, es, it, ar, tr, ru, nl, pt
  locationId             String?
  galleries              Gallery[]
  orders                 Order[]
  shopOrders             ShopOrder[]      @relation("ShopOrders")
  checkInDate            DateTime?
  checkOutDate           DateTime?
  cartAbandoned          Boolean          @default(false)
  cartAbandonedAt        DateTime?
  lastViewedAt           DateTime?
  preArrivalOfferSentAt  DateTime?
  checkoutReminderSentAt DateTime?
  packageBookings        PackageBooking[]
  createdAt              DateTime         @default(now())

  @@index([whatsapp])
  @@index([wristbandCode])
  @@index([email])
  @@index([locationId])
}

enum DigitalPassType {
  BASIC
  UNLIMITED
  VIP
}

// ── GALLERIES ─────────────────────────────────
model Gallery {
  id              String           @id @default(cuid())
  magicLinkToken  String           @unique @default(cuid())
  status          GalleryStatus
  locationId      String
  location        Location         @relation(fields: [locationId], references: [id])
  photographerId  String
  photographer    User             @relation("PhotographerGalleries", fields: [photographerId], references: [id])
  customerId      String
  customer        Customer         @relation(fields: [customerId], references: [id])
  roomNumber      String?
  photos          Photo[]
  videos          Video[]
  hookImageId     String?
  expiresAt       DateTime
  appointment     Appointment?
  order           Order?
  partialPurchase Boolean          @default(false)
  purchasedCount  Int              @default(0)
  totalCount      Int              @default(0)
  sweepUpSentAt   DateTime?
  discountPercent Float?
  coverMessage    String?
  accessPassword  String?
  downloadPin     String?
  maxDownloads    Int?
  shortCode       String?          @unique
  galleryCode     String?
  galleryTheme    String           @default("classic")
  editQuality     EditQuality      @default(STANDARD)
  requireEmail    Boolean          @default(false)
  expiryWarning14 DateTime?
  expiryWarning7  DateTime?
  expiryWarning48 DateTime?
  expiryFinalSent DateTime?
  downloadLogs    DownloadLog[]
  viewLogs        GalleryViewLog[]
  photoSets       PhotoSet[]
  videoReels      VideoReel[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([locationId])
  @@index([photographerId])
  @@index([expiresAt])
  @@index([customerId])
}

enum GalleryStatus {
  HOOK_ONLY
  PREVIEW_ECOM
  PAID
  PARTIAL_PAID
  DIGITAL_PASS
  EXPIRED
}

// ── PHOTOS & VIDEOS ───────────────────────────
model Photo {
  id                     String         @id @default(cuid())
  galleryId              String
  gallery                Gallery        @relation(fields: [galleryId], references: [id])
  s3Key_highRes          String
  s3Key_raw              String?
  cloudinaryId           String?
  isHookImage            Boolean        @default(false)
  isFavorited            Boolean        @default(false)
  isPurchased            Boolean        @default(false)
  isRetouched            Boolean        @default(false)
  aiCulled               Boolean        @default(false)
  aiCullReason           String?
  hasMagicElement        Boolean        @default(false)
  magicElementId         String?
  isMagicShot            Boolean        @default(false)
  parentPhotoId          String?
  setId                  String?
  set                    PhotoSet?      @relation(fields: [setId], references: [id])
  sortOrder              Int            @default(0)
  cloudinaryId_edited    String?
  isAutoEdited           Boolean        @default(false)
  editApplied            String[]       @default([])
  analysis               PhotoAnalysis?
  aiScore                Int?
  aiStatus               AiCullStatus   @default(PENDING)
  isWristbandPhoto       Boolean        @default(false)
  extractedWristbandCode String?
  // Face recognition
  faceTokens             String? // JSON array of face_token strings from Face++
  faceBounds             String? // JSON array of {top,left,width,height} bounding boxes
  faceCount              Int            @default(0)
  faceIndexedAt          DateTime?
  createdAt              DateTime       @default(now())

  @@index([galleryId])
  @@index([isPurchased])
  @@index([aiCulled])
  @@index([aiStatus])
  @@index([faceCount])
}

model Video {
  id             String    @id @default(cuid())
  galleryId      String
  gallery        Gallery   @relation(fields: [galleryId], references: [id])
  s3Key          String
  type           VideoType
  duration       Int?
  isAutoReel     Boolean   @default(false)
  musicTrackId   String?
  graphicOverlay String?
  createdAt      DateTime  @default(now())
}

enum AiCullStatus {
  PENDING
  KEEP
  MAYBE
  REJECT
}

enum VideoType {
  RAW_CLIP
  SLOW_MOTION
  AUTO_REEL
  HIGHLIGHT
}

// ── APPOINTMENTS & BOOKINGS ───────────────────
model Appointment {
  id                     String            @id @default(cuid())
  galleryId              String?           @unique
  gallery                Gallery?          @relation(fields: [galleryId], references: [id])
  scheduledTime          DateTime
  status                 AppointmentStatus
  assignedPhotographerId String
  assignedPhotographer   User              @relation("AssignedPhotographer", fields: [assignedPhotographerId], references: [id])
  source                 BookingSource
  sourceDetail           String?
  externalRef            String?
  notes                  String?
  customerName           String?
  customerPhone          String?
  customerEmail          String?
  partySize              Int               @default(1)
  sessionType            String            @default("STANDARD")
  estimatedDuration      Int               @default(30)
  specialRequests        String?
  locationId             String?
  location               Location?         @relation(fields: [locationId], references: [id])
  qrCodeId               String?
  qrCode                 QRCode?           @relation(fields: [qrCodeId], references: [id])
  packageBooking         PackageBooking?
  createdAt              DateTime          @default(now())
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  NO_SHOW
}

enum BookingSource {
  HOOK_GALLERY
  QR_CODE
  VIP_BOOKING
  WALK_IN
  PRE_ARRIVAL
  WEBSITE
  INSTAGRAM
  FACEBOOK
  EMAIL
  PHONE
  PACKAGE_BOOKING
  WHATSAPP
  HOTEL_CONCIERGE
  PARTNER_REFERRAL
}

// ── ORDERS & PAYMENTS ─────────────────────────
model Order {
  id              String             @id @default(cuid())
  galleryId       String             @unique
  gallery         Gallery            @relation(fields: [galleryId], references: [id])
  customerId      String
  customer        Customer           @relation(fields: [customerId], references: [id])
  amount          Float
  currency        String             @default("EUR")
  paymentMethod   PaymentMethod
  stripeSessionId String?
  stripePaymentId String?
  cashPin         String?
  status          OrderStatus
  items           OrderItem[]
  commissions     Commission[]
  printJobs       PrintJob[]
  fulfillments    FulfillmentOrder[]
  isAutomatedSale Boolean            @default(false)
  discountApplied Float?
  // Financial tracking — Stripe fee & net amount for accurate margin calculation
  stripeFee       Float              @default(0) // Stripe processing fee (2.9% + €0.30)
  netAmount       Float? // amount minus stripeFee — actual cash received
  taxAmount       Float              @default(0) // VAT/tax collected
  taxRate         Float              @default(0) // Tax rate applied (e.g., 0.19 for 19%)
  refundedAmount  Float              @default(0)
  refundedAt      DateTime?
  refundReason    String?
  refundedBy      String?
  stripeRefundId  String?
  reelPreviewUrl  String?
  reelFullUrl     String?
  reelStatus      String? // PREVIEW_READY, PURCHASED, GENERATING_FULL, DELIVERED
  reelTier        String? // SHORT, STANDARD, PREMIUM
  createdAt       DateTime           @default(now())

  @@index([status])
  @@index([createdAt])
  @@index([customerId])
}

model OrderItem {
  id        String        @id @default(cuid())
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id])
  type      OrderItemType
  photoId   String?
  videoId   String?
  quantity  Int           @default(1)
  unitPrice Float
}

enum OrderItemType {
  SINGLE_PHOTO
  FULL_GALLERY
  PARTIAL_GALLERY
  PRINTED_ALBUM
  VIDEO_CLIP
  AUTO_REEL
  MAGIC_SHOT
  DIGITAL_PASS
  SOCIAL_MEDIA_PACKAGE
}

enum PaymentMethod {
  STRIPE_ONLINE
  STRIPE_TERMINAL
  CASH
  PAYPAL
}

enum OrderStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

// ── COMMISSIONS & PAYROLL ─────────────────────
model Commission {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  orderId     String?
  order       Order?           @relation(fields: [orderId], references: [id])
  bookingId   String? // For marketplace booking commissions
  type        CommissionType
  grossAmount Float? // Original sale amount (before fees)
  netAmount   Float? // After Stripe fees
  amount      Float // Commission amount the user earns
  rate        Float
  status      CommissionStatus @default(PENDING)
  isPaid      Boolean          @default(false)
  paidAt      DateTime?
  month       String?
  notes       String? // Adjustments, reversals
  createdAt   DateTime         @default(now())

  @@index([userId])
  @@index([month])
  @@index([isPaid])
  @@index([status])
}

enum CommissionStatus {
  PENDING // Awaiting approval
  APPROVED // Approved for payout
  PAID // Paid out
  REVERSED // Reversed due to refund
  ADJUSTED // Manual adjustment
}

enum CommissionType {
  PHOTO_SALE
  DIGITAL_PASS_SALE
  APPOINTMENT_BOOKING
  QR_REFERRAL
  SLEEPING_MONEY
  ATTENDANCE_BONUS
  PACKAGE_BOOKING
}

// ── QR CODES ──────────────────────────────────
model QRCode {
  id                String        @id @default(cuid())
  code              String        @unique
  type              QRCodeType
  locationId        String
  location          Location      @relation(fields: [locationId], references: [id])
  assignedToStaffId String?
  customerId        String?
  roomNumber        String?
  scanCount         Int           @default(0)
  appointments      Appointment[]
  createdAt         DateTime      @default(now())
}

enum QRCodeType {
  HOTEL_ROOM
  RECEPTION_DESK
  LOBBY_SIGN
  WRISTBAND
  WELCOME_ARCHWAY
}

// ── EQUIPMENT TRACKING ────────────────────────
model Equipment {
  id           String                @id @default(cuid())
  name         String
  type         String
  serialNumber String?
  purchaseCost Float?
  locationId   String
  location     Location              @relation(fields: [locationId], references: [id])
  assignments  EquipmentAssignment[]
  status       EquipmentStatus       @default(AVAILABLE)
}

enum EquipmentStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

model EquipmentAssignment {
  id          String    @id @default(cuid())
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  assignedAt  DateTime  @default(now())
  returnedAt  DateTime?
}

// ── STAFF MANAGEMENT ──────────────────────────
model Shift {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  date       DateTime
  startTime  DateTime
  endTime    DateTime
  locationId String
}

model StaffHousing {
  id                String           @id @default(cuid())
  userId            String           @unique
  user              User             @relation(fields: [userId], references: [id])
  propertyName      String?
  address           String
  type              String? // APARTMENT, SHARED_ROOM, HOTEL_ROOM, STUDIO
  capacity          Int              @default(1)
  monthlyCost       Float
  deposit           Float?
  utilitiesIncluded Boolean          @default(false)
  wifiIncluded      Boolean          @default(false)
  distanceToResort  String?
  contractStart     DateTime?
  contractEnd       DateTime?
  notes             String?
  documentation     String?
  expenses          HousingExpense[]
  createdAt         DateTime         @default(now())
}

model HousingExpense {
  id        String       @id @default(cuid())
  housingId String
  housing   StaffHousing @relation(fields: [housingId], references: [id], onDelete: Cascade)
  type      String // RENT, UTILITIES, REPAIR, DEPOSIT, FURNITURE, CLEANING
  amount    Float
  date      DateTime
  paidBy    String // COMPANY, STAFF, SHARED
  receipt   String?
  notes     String?
  createdAt DateTime     @default(now())

  @@index([housingId])
  @@index([date])
}

model StaffTransfer {
  id             String   @id @default(cuid())
  userId         String
  fromLocationId String
  toLocationId   String
  transferDate   DateTime
  reason         String?
  approvedBy     String?
  createdAt      DateTime @default(now())
}

// ── CHAT & COMMUNICATION ──────────────────────
model ChatChannel {
  id          String          @id @default(cuid())
  name        String
  type        ChatChannelType
  description String?
  locationId  String?
  location    Location?       @relation(fields: [locationId], references: [id])
  role        String? // For ROLE-type channels (e.g., "PHOTOGRAPHER")
  isSystem    Boolean         @default(false)
  members     ChatMember[]
  messages    ChatMessage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum ChatChannelType {
  LOCATION
  ROLE
  DIRECT
  ANNOUNCEMENT
}

model ChatMember {
  id         String      @id @default(cuid())
  channelId  String
  channel    ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  lastReadAt DateTime    @default(now())
  joinedAt   DateTime    @default(now())

  @@unique([channelId, userId])
  @@index([userId])
}

model ChatMessage {
  id        String          @id @default(cuid())
  channelId String
  channel   ChatChannel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId  String?
  sender    User?           @relation(fields: [senderId], references: [id])
  content   String
  type      ChatMessageType @default(TEXT)
  edited    Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @default(now()) @updatedAt

  @@index([channelId, createdAt])
}

enum ChatMessageType {
  TEXT
  IMAGE
  SYSTEM
  ALERT
  AI_TIP
}

// ── AI & CONTENT ──────────────────────────────
model BlogPost {
  id             String        @id @default(cuid())
  title          String
  content        String
  authorId       String
  author         User          @relation(fields: [authorId], references: [id])
  isAIGenerated  Boolean       @default(true)
  status         ContentStatus @default(DRAFT)
  seoKeywords    String[]
  featuredPhotos String[]
  createdAt      DateTime      @default(now())
  publishedAt    DateTime?
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model AIGrowthLog {
  id           String       @id @default(cuid())
  type         AIActionType
  description  String
  result       String?
  dataSnapshot Json?
  createdAt    DateTime     @default(now())
}

enum AIActionType {
  STAFF_PROMOTION_SUGGESTION
  PRICING_OPTIMIZATION
  PARTNER_DISCOVERY
  SEO_UPDATE
  MARKETING_CAMPAIGN
  BOOKING_BOOST
  PHOTOGRAPHER_PERFORMANCE_FLAG
  FRANCHISE_LEAD
}

// ── B2B MEDIA BARTER ──────────────────────────
model B2BDelivery {
  id                  String    @id @default(cuid())
  locationId          String
  location            Location  @relation(fields: [locationId], references: [id])
  month               String
  photoCount          Int
  deliveredAt         DateTime?
  rentDiscountPercent Float?
  notes               String?
}

// ── MAGIC ELEMENTS (AR/3D) ────────────────────
model MagicElement {
  id          String           @id @default(cuid())
  name        String
  slug        String?          @unique
  type        MagicElementType
  assetUrl    String
  category    String? // FACE_OVERLAY | BACKGROUND | FRAME | EFFECT
  position    String? // TOP | CENTER | FACE | BORDER | SCATTER
  description String?
  usageCount  Int              @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
}

enum MagicElementType {
  THREE_D_CHARACTER
  AR_OVERLAY
  BACKGROUND_REPLACE
  GRAPHIC_OVERLAY
}

// ── ACADEMY & HR ──────────────────────────────
model AcademyModule {
  id                  String               @id @default(cuid())
  title               String
  description         String
  type                AcademyModuleType
  contentUrl          String?
  sortOrder           Int
  isRequired          Boolean              @default(false)
  trainingAssignments TrainingAssignment[]
}

enum AcademyModuleType {
  ONBOARDING
  SALES_TRAINING
  PHOTOGRAPHY_TECHNIQUE
  SOFTWARE_TRAINING
  COMPLIANCE
}

model AcademyProgress {
  id          String    @id @default(cuid())
  userId      String
  moduleId    String
  completed   Boolean   @default(false)
  completedAt DateTime?
  score       Float?
}

model JobPosting {
  id           String           @id @default(cuid())
  title        String
  locationId   String?
  requirements String
  status       JobStatus        @default(OPEN)
  applications JobApplication[]
