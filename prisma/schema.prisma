model UpsellScript {
  id             String   @id @default(cuid())
  scriptName     String
  trigger        String
  condition      String
  script         String
  demographic    String?
  locationType   String?
  priority       Int      @default(0)
  isActive       Boolean  @default(true)
  conversionRate Float    @default(0)
  timesShown     Int      @default(0)
  timesConverted Int      @default(0)
  createdAt      DateTime @default(now())
}

model ApproachHook {
  id           String   @id @default(cuid())
  name         String
  demographic  String?
  location     String?
  locationType String?
  timeOfDay    String?
  script       String
  notes        String?
  successRate  Float    @default(0)
  timesUsed    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model AppointmentOutcome {
  id             String    @id @default(cuid())
  appointmentId  String    @unique
  arrivedAt      DateTime?
  didArrive      Boolean   @default(false)
  didBuy         Boolean   @default(false)
  orderAmount    Float?
  hookUsed       String?
  noShowReason   String?
  photographerId String?
  photographer   User?     @relation("UserAppointmentOutcomes", fields: [photographerId], references: [id])
  createdAt      DateTime  @default(now())
}

model SneakPeek {
  id              String   @id @default(cuid())
  customerId      String
  galleryId       String
  photoId         String?
  sentAt          DateTime @default(now())
  wasOpened       Boolean  @default(false)
  customerArrived Boolean  @default(false)
}

model ZoneAssignment {
  id             String    @id @default(cuid())
  photographerId String
  photographer   User      @relation("UserZoneAssignments", fields: [photographerId], references: [id])
  locationId     String
  zoneName       String
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  isOutdoor      Boolean   @default(false)
  temperature    Float?
  rotatedOnTime  Boolean?
}

model SiteEvaluation {
  id               String   @id @default(cuid())
  locationId       String?
  locationName     String
  evaluatedBy      String?
  trafficScore     Int
  affluenceScore   Int
  spaceScore       Int
  partnerScore     Int
  competitionScore Int
  totalScore       Int
  passed           Boolean
  expectedTraffic  Int?
  expectedAOV      Float?
  monthlyGross     Float?
  rentCeiling      Float?
  proposedRent     Float?
  status           String   @default("DRAFT")
  createdAt        DateTime @default(now())
}

model ScalingGate {
  id          String    @id @default(cuid())
  orgId       String
  gateNumber  Int
  gateName    String
  requirement String
  passed      Boolean   @default(false)
  passedAt    DateTime?
  evidence    String?

  @@unique([orgId, gateNumber])
}

model ProofSubmission {
  id          String    @id @default(cuid())
  locationId  String
  month       String
  type        String
  status      String    @default("pending")
  fileUrl     String?
  submittedBy String?
  submittedAt DateTime?
  verifiedBy  String?
  verifiedAt  DateTime?
  notes       String?

  @@unique([locationId, month, type])
}

model KioskEvent {
  id         String   @id @default(cuid())
  type       String
  photoCount Int?
  amount     Float?
  locationId String?
  createdAt  DateTime @default(now())
}
