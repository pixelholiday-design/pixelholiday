// ── GIFT CARDS & STORE CREDITS ──────────────
model GiftCard {
  id                 String               @id @default(cuid())
  code               String               @unique // "PH-GIFT-XXXX-XXXX"
  amount             Float // original amount e.g. 50
  balance            Float // remaining balance
  currency           String               @default("EUR")
  purchasedBy        String? // customer name or email who bought it
  redeemedBy         String? // customer who used it
  locationId         String? // can be location-specific or global
  type               String               @default("GIFT") // GIFT, STORE_CREDIT, HOTEL_PACKAGE, REFUND_CREDIT
  expiresAt          DateTime?
  isActive           Boolean              @default(true)
  stripeSessionId    String?
  // Revenue recognition — gift cards are DEFERRED REVENUE until redeemed
  totalRedeemed      Float                @default(0) // Cumulative amount redeemed (recognized as revenue)
  breakageRecognized Boolean              @default(false) // True if unredeemed balance was recognized as breakage
  breakageAmount     Float                @default(0) // Amount recognized as breakage revenue
  breakageDate       DateTime? // Date breakage was recognized
  redemptions        GiftCardRedemption[]
  createdAt          DateTime             @default(now())

  @@index([code])
  @@index([isActive])
  @@index([expiresAt])
}

// Track individual gift card redemptions for audit trail
model GiftCardRedemption {
  id          String   @id @default(cuid())
  giftCardId  String
  giftCard    GiftCard @relation(fields: [giftCardId], references: [id])
  amount      Float // Amount redeemed in this transaction
  orderId     String? // Linked order, if applicable
  shopOrderId String? // Linked shop order, if applicable
  redeemedBy  String? // Customer identifier
  createdAt   DateTime @default(now())

  @@index([giftCardId])
}

