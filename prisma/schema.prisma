// PixelHoliday master Prisma schema — see CLAUDE.md Section 1
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── USERS & AUTH ──────────────────────────────
model Organization {
  id                 String           @id @default(cuid())
  name               String
  type               OrgType
  parentOrgId        String?
  parentOrg          Organization?    @relation("FranchiseTree", fields: [parentOrgId], references: [id])
  children           Organization[]   @relation("FranchiseTree")
  locations          Location[]
  staff              User[]
  subscriptionTier   SubscriptionTier @default(STARTER)
  saasCommissionRate Float            @default(0.02)
  sleepingMoneyShare Float            @default(0.50)
  createdAt          DateTime         @default(now())
}

model User {
  id                   String                    @id @default(cuid())
  name                 String
  email                String                    @unique
  password             String?
  phone                String?
  pin                  String?
  role                 StaffRole
  orgId                String
  org                  Organization              @relation(fields: [orgId], references: [id])
  locationId           String?
  location             Location?                 @relation(fields: [locationId], references: [id])
  isRepeater           Boolean                   @default(false)
  repeaterYears        Int                       @default(0)
  salary               Float?
  rating               Float                     @default(0)
  equipmentAssignments EquipmentAssignment[]
  galleries            Gallery[]                 @relation("PhotographerGalleries")
  appointments         Appointment[]             @relation("AssignedPhotographer")
  commissions          Commission[]
  shifts               Shift[]
  housing              StaffHousing?
  blogPosts            BlogPost[]
  chatMessages         ChatMessage[]
  xp                   Int                       @default(0)
  level                Int                       @default(1)
  badges               String[]                  @default([])
  streakDays           Int                       @default(0)
  lastActivityAt       DateTime?
  userBadges           UserBadge[]
  xpLogs               XpLog[]
  photoAnalyses        PhotoAnalysis[]           @relation("PhotographerAnalyses")
  skillProfile         PhotographerSkillProfile? @relation("UserSkillProfile")
  trainingAssignments  TrainingAssignment[]      @relation("UserTrainingAssignments")
  weeklySkillReports   WeeklySkillReport[]       @relation("UserWeeklyReports")
  zoneAssignments      ZoneAssignment[]          @relation("UserZoneAssignments")
  appointmentOutcomes  AppointmentOutcome[]      @relation("UserAppointmentOutcomes")
  createdAt            DateTime                  @default(now())
}

enum StaffRole {
  CEO
  OPERATIONS_MANAGER
  SUPERVISOR
  PHOTOGRAPHER
  SALES_STAFF
  RECEPTIONIST
  ACADEMY_TRAINEE
}

enum OrgType {
  HEADQUARTERS
  FRANCHISE
}

enum SubscriptionTier {
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

// ── LOCATIONS ─────────────────────────────────
model Location {
  id                 String          @id @default(cuid())
  name               String
  type               LocationType
  orgId              String
  org                Organization    @relation(fields: [orgId], references: [id])
  address            String?
  partnerCommission  Float?
  rentCost           Float?
  qrCodes            QRCode[]
  staff              User[]
  galleries          Gallery[]
  equipment          Equipment[]
  b2bDeliveries      B2BDelivery[]
  cameras            Camera[]
  kiosks             KioskDevice[]
  cashRegisters      CashRegister[]
  locationType       String          @default("LUXURY")
  targetAOV          Float?
  maxShiftHours      Int             @default(8)
  siestaStart        String?
  siestaEnd          String?
  country            String          @default("Tunisia")
  city               String?
  timezone           String          @default("Africa/Tunis")
  currency           String          @default("EUR")
  taxRate            Float           @default(0.19)
  rentAmount         Float?
  rentType           String?
  rentPercentage     Float?
  targetDailyRevenue Float?
  targetCaptureRate  Float?
  scheduleType       String          @default("SIESTA")
  morningStart       String?
  morningEnd         String?
  eveningStart       String?
  eveningEnd         String?
  rotationHours      Int?
  commissionType     String          @default("FLAT")
  commissionRate     Float           @default(0.10)
  attendanceBonus    Float           @default(2.0)
  vipCloserBonus     Float           @default(0.05)
  tier1Threshold     Float?
  tier1Rate          Float?
  tier2Threshold     Float?
  tier2Rate          Float?
  tier3Rate          Float?
  supervisorOverride Float?
  partnerName        String?
  partnerContact     String?
  partnerEmail       String?
  partnerPhone       String?
  roomCount          Int?
  occupancyRate      Float?
  contractStartDate  DateTime?
  contractEndDate    DateTime?
  isActive           Boolean         @default(true)
  pricingConfigs     PricingConfig[]
  appointments       Appointment[]
  createdAt          DateTime        @default(now())
}

enum LocationType {
  HOTEL
  WATER_PARK
  ATTRACTION
  SELF_SERVICE
}

// ── CUSTOMERS ─────────────────────────────────
model Customer {
  id              String           @id @default(cuid())
  name            String?
  email           String?
  whatsapp        String?
  roomNumber      String?
  faceVector      Bytes?
  wristbandCode   String?
  nfcTag          String?
  hasDigitalPass  Boolean          @default(false)
  digitalPassType DigitalPassType?
  locationId      String?
  galleries       Gallery[]
  orders          Order[]
  cartAbandoned   Boolean          @default(false)
  cartAbandonedAt DateTime?
  lastViewedAt    DateTime?
  createdAt       DateTime         @default(now())

  @@index([whatsapp])
  @@index([wristbandCode])
  @@index([email])
  @@index([locationId])
}

enum DigitalPassType {
  BASIC
  UNLIMITED
  VIP
}

// ── GALLERIES ─────────────────────────────────
model Gallery {
  id              String           @id @default(cuid())
  magicLinkToken  String           @unique @default(cuid())
  status          GalleryStatus
  locationId      String
  location        Location         @relation(fields: [locationId], references: [id])
  photographerId  String
  photographer    User             @relation("PhotographerGalleries", fields: [photographerId], references: [id])
  customerId      String
  customer        Customer         @relation(fields: [customerId], references: [id])
  roomNumber      String?
  photos          Photo[]
  videos          Video[]
  hookImageId     String?
  expiresAt       DateTime
  appointment     Appointment?
  order           Order?
  partialPurchase Boolean          @default(false)
  purchasedCount  Int              @default(0)
  totalCount      Int              @default(0)
  sweepUpSentAt   DateTime?
  discountPercent Float?
  coverMessage    String?
  accessPassword  String?
  downloadPin     String?
  editQuality     EditQuality      @default(STANDARD)
  downloadLogs    DownloadLog[]
  viewLogs        GalleryViewLog[]
  photoSets       PhotoSet[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([locationId])
  @@index([photographerId])
  @@index([expiresAt])
  @@index([customerId])
}

enum GalleryStatus {
  HOOK_ONLY
  PREVIEW_ECOM
  PAID
  PARTIAL_PAID
  DIGITAL_PASS
  EXPIRED
}

// ── PHOTOS & VIDEOS ───────────────────────────
model Photo {
  id                     String         @id @default(cuid())
  galleryId              String
  gallery                Gallery        @relation(fields: [galleryId], references: [id])
  s3Key_highRes          String
  s3Key_raw              String?
  cloudinaryId           String?
  isHookImage            Boolean        @default(false)
  isFavorited            Boolean        @default(false)
  isPurchased            Boolean        @default(false)
  isRetouched            Boolean        @default(false)
  aiCulled               Boolean        @default(false)
  aiCullReason           String?
  hasMagicElement        Boolean        @default(false)
  magicElementId         String?
  setId                  String?
  set                    PhotoSet?      @relation(fields: [setId], references: [id])
  sortOrder              Int            @default(0)
  cloudinaryId_edited    String?
  isAutoEdited           Boolean        @default(false)
  editApplied            String[]       @default([])
  analysis               PhotoAnalysis?
  isWristbandPhoto       Boolean        @default(false)
  extractedWristbandCode String?
  createdAt              DateTime       @default(now())

  @@index([galleryId])
  @@index([isPurchased])
  @@index([aiCulled])
}

model Video {
  id             String    @id @default(cuid())
  galleryId      String
  gallery        Gallery   @relation(fields: [galleryId], references: [id])
  s3Key          String
  type           VideoType
  duration       Int?
  isAutoReel     Boolean   @default(false)
  musicTrackId   String?
  graphicOverlay String?
  createdAt      DateTime  @default(now())
}

enum VideoType {
  RAW_CLIP
  SLOW_MOTION
  AUTO_REEL
  HIGHLIGHT
}

// ── APPOINTMENTS & BOOKINGS ───────────────────
model Appointment {
  id                     String            @id @default(cuid())
  galleryId              String?           @unique
  gallery                Gallery?          @relation(fields: [galleryId], references: [id])
  scheduledTime          DateTime
  status                 AppointmentStatus
  assignedPhotographerId String
  assignedPhotographer   User              @relation("AssignedPhotographer", fields: [assignedPhotographerId], references: [id])
  source                 BookingSource
  sourceDetail           String?
  externalRef            String?
  notes                  String?
  customerName           String?
  customerPhone          String?
  customerEmail          String?
  partySize              Int               @default(1)
  sessionType            String            @default("STANDARD")
  estimatedDuration      Int               @default(30)
  specialRequests        String?
  locationId             String?
  location               Location?         @relation(fields: [locationId], references: [id])
  qrCodeId               String?
  qrCode                 QRCode?           @relation(fields: [qrCodeId], references: [id])
  createdAt              DateTime          @default(now())
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  NO_SHOW
}

enum BookingSource {
  HOOK_GALLERY
  QR_CODE
  VIP_BOOKING
  WALK_IN
  PRE_ARRIVAL
  WEBSITE
}

// ── ORDERS & PAYMENTS ─────────────────────────
model Order {
  id              String             @id @default(cuid())
  galleryId       String             @unique
  gallery         Gallery            @relation(fields: [galleryId], references: [id])
  customerId      String
  customer        Customer           @relation(fields: [customerId], references: [id])
  amount          Float
  currency        String             @default("EUR")
  paymentMethod   PaymentMethod
  stripeSessionId String?
  stripePaymentId String?
  cashPin         String?
  status          OrderStatus
  items           OrderItem[]
  commissions     Commission[]
  printJobs       PrintJob[]
  fulfillments    FulfillmentOrder[]
  isAutomatedSale Boolean            @default(false)
  discountApplied Float?
  createdAt       DateTime           @default(now())

  @@index([status])
  @@index([createdAt])
  @@index([customerId])
}

model OrderItem {
  id        String        @id @default(cuid())
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id])
  type      OrderItemType
  photoId   String?
  videoId   String?
  quantity  Int           @default(1)
  unitPrice Float
}

enum OrderItemType {
  SINGLE_PHOTO
  FULL_GALLERY
  PARTIAL_GALLERY
  PRINTED_ALBUM
  VIDEO_CLIP
  AUTO_REEL
  MAGIC_SHOT
  DIGITAL_PASS
  SOCIAL_MEDIA_PACKAGE
}

enum PaymentMethod {
  STRIPE_ONLINE
  STRIPE_TERMINAL
  CASH
}

enum OrderStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

// ── COMMISSIONS & PAYROLL ─────────────────────
model Commission {
  id      String         @id @default(cuid())
  userId  String
  user    User           @relation(fields: [userId], references: [id])
  orderId String?
  order   Order?         @relation(fields: [orderId], references: [id])
  type    CommissionType
  amount  Float
  rate    Float
  isPaid  Boolean        @default(false)
  paidAt  DateTime?
  month   String?

  @@index([userId])
  @@index([month])
  @@index([isPaid])
}

enum CommissionType {
  PHOTO_SALE
  DIGITAL_PASS_SALE
  APPOINTMENT_BOOKING
  QR_REFERRAL
  SLEEPING_MONEY
  ATTENDANCE_BONUS
}

// ── QR CODES ──────────────────────────────────
model QRCode {
  id                String        @id @default(cuid())
  code              String        @unique
  type              QRCodeType
  locationId        String
  location          Location      @relation(fields: [locationId], references: [id])
  assignedToStaffId String?
  scanCount         Int           @default(0)
  appointments      Appointment[]
  createdAt         DateTime      @default(now())
}

enum QRCodeType {
  HOTEL_ROOM
  RECEPTION_DESK
  LOBBY_SIGN
  WRISTBAND
  WELCOME_ARCHWAY
}

// ── EQUIPMENT TRACKING ────────────────────────
model Equipment {
  id           String                @id @default(cuid())
  name         String
  type         String
  serialNumber String?
  purchaseCost Float?
  locationId   String
  location     Location              @relation(fields: [locationId], references: [id])
  assignments  EquipmentAssignment[]
  status       EquipmentStatus       @default(AVAILABLE)
}

enum EquipmentStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

model EquipmentAssignment {
  id          String    @id @default(cuid())
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  assignedAt  DateTime  @default(now())
  returnedAt  DateTime?
}

// ── STAFF MANAGEMENT ──────────────────────────
model Shift {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  date       DateTime
  startTime  DateTime
  endTime    DateTime
  locationId String
}

model StaffHousing {
  id            String  @id @default(cuid())
  userId        String  @unique
  user          User    @relation(fields: [userId], references: [id])
  address       String
  monthlyCost   Float
  documentation String?
}

model StaffTransfer {
  id             String   @id @default(cuid())
  userId         String
  fromLocationId String
  toLocationId   String
  transferDate   DateTime
  reason         String?
  approvedBy     String?
  createdAt      DateTime @default(now())
}

// ── CHAT & COMMUNICATION ──────────────────────
model ChatMessage {
  id        String   @id @default(cuid())
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  channelId String
  content   String
  createdAt DateTime @default(now())
}

// ── AI & CONTENT ──────────────────────────────
model BlogPost {
  id             String        @id @default(cuid())
  title          String
  content        String
  authorId       String
  author         User          @relation(fields: [authorId], references: [id])
  isAIGenerated  Boolean       @default(true)
  status         ContentStatus @default(DRAFT)
  seoKeywords    String[]
  featuredPhotos String[]
  createdAt      DateTime      @default(now())
  publishedAt    DateTime?
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model AIGrowthLog {
  id           String       @id @default(cuid())
  type         AIActionType
  description  String
  result       String?
  dataSnapshot Json?
  createdAt    DateTime     @default(now())
}

enum AIActionType {
  STAFF_PROMOTION_SUGGESTION
  PRICING_OPTIMIZATION
  PARTNER_DISCOVERY
  SEO_UPDATE
  MARKETING_CAMPAIGN
  BOOKING_BOOST
  PHOTOGRAPHER_PERFORMANCE_FLAG
  FRANCHISE_LEAD
}

// ── B2B MEDIA BARTER ──────────────────────────
model B2BDelivery {
  id                  String    @id @default(cuid())
  locationId          String
  location            Location  @relation(fields: [locationId], references: [id])
  month               String
  photoCount          Int
  deliveredAt         DateTime?
  rentDiscountPercent Float?
  notes               String?
}

// ── MAGIC ELEMENTS (AR/3D) ────────────────────
model MagicElement {
  id       String           @id @default(cuid())
  name     String
  type     MagicElementType
  assetUrl String
  category String?
  isActive Boolean          @default(true)
}

enum MagicElementType {
  THREE_D_CHARACTER
  AR_OVERLAY
  BACKGROUND_REPLACE
  GRAPHIC_OVERLAY
}

// ── ACADEMY & HR ──────────────────────────────
model AcademyModule {
  id                  String               @id @default(cuid())
  title               String
  description         String
  type                AcademyModuleType
  contentUrl          String?
  sortOrder           Int
  isRequired          Boolean              @default(false)
  trainingAssignments TrainingAssignment[]
}

enum AcademyModuleType {
  ONBOARDING
  SALES_TRAINING
  PHOTOGRAPHY_TECHNIQUE
  SOFTWARE_TRAINING
  COMPLIANCE
}

model AcademyProgress {
  id          String    @id @default(cuid())
  userId      String
  moduleId    String
  completed   Boolean   @default(false)
  completedAt DateTime?
  score       Float?
}

model JobPosting {
  id           String           @id @default(cuid())
  title        String
  locationId   String?
  requirements String
  status       JobStatus        @default(OPEN)
  applications JobApplication[]
  createdAt    DateTime         @default(now())
}

enum JobStatus {
  OPEN
  FILLED
  CLOSED
}

model JobApplication {
  id             String            @id @default(cuid())
  jobId          String
  job            JobPosting        @relation(fields: [jobId], references: [id])
  applicantName  String
  applicantEmail String
  cvUrl          String?
  status         ApplicationStatus @default(RECEIVED)
  createdAt      DateTime          @default(now())
}

enum ApplicationStatus {
  RECEIVED
  SHORTLISTED
  INTERVIEWED
  OFFERED
  REJECTED
}

model ProcessedWebhookEvent {
  id        String   @id
  source    String
  createdAt DateTime @default(now())
}

model Camera {
  id           String     @id @default(cuid())
  name         String
  externalId   String     @unique
  locationId   String
  location     Location   @relation(fields: [locationId], references: [id])
  type         CameraType
  isActive     Boolean    @default(true)
  lastPingAt   DateTime?
  captureCount Int        @default(0)
  createdAt    DateTime   @default(now())
}

enum CameraType {
  SPEED_CAM
  RIDE_CAM
  ENTRANCE_CAM
  ROAMING
}

model KioskDevice {
  id              String    @id @default(cuid())
  name            String
  externalId      String    @unique
  locationId      String
  location        Location  @relation(fields: [locationId], references: [id])
  isOnline        Boolean   @default(false)
  lastPingAt      DateTime?
  todaySalesCents Int       @default(0)
  createdAt       DateTime  @default(now())
}

model PrintJob {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id])
  status    PrintStatus @default(PENDING)
  photoIds  String[]
  printSize String      @default("4x6")
  copies    Int         @default(1)
  printedAt DateTime?
  printedBy String?
  createdAt DateTime    @default(now())
}

enum PrintStatus {
  PENDING
  PRINTING
  COMPLETED
  FAILED
}

model PricingConfig {
  id                 String    @id @default(cuid())
  productKey         String
  name               String
  price              Float
  currency           String    @default("EUR")
  isActive           Boolean   @default(true)
  isAnchor           Boolean   @default(false)
  isHidden           Boolean   @default(false)
  displayOrder       Int       @default(0)
  anchorDelaySeconds Int       @default(10)
  locationId         String?
  location           Location? @relation(fields: [locationId], references: [id])
  updatedBy          String?
  updatedAt          DateTime  @updatedAt
  createdAt          DateTime  @default(now())

  @@unique([productKey, locationId])
}

model SaleOrder {
  id            String          @id @default(cuid())
  galleryId     String
  customerId    String
  photoIds      String[]
  totalCents    Int
  status        SaleOrderStatus @default(PENDING)
  paymentMethod String?
  receivedCents Int?
  changeCents   Int?
  staffId       String?
  receiptCode   String          @unique @default(cuid())
  createdAt     DateTime        @default(now())
  completedAt   DateTime?
}

enum SaleOrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model PricingHistory {
  id         String   @id @default(cuid())
  productKey String
  oldPrice   Float
  newPrice   Float
  changedBy  String?
  createdAt  DateTime @default(now())
}

model Campaign {
  id          String   @id @default(cuid())
  type        String // "ABANDONED_CART_3D" | "SWEEP_UP_7D" | custom
  name        String
  enabled     Boolean  @default(true)
  discountPct Float
  delayDays   Int
  template    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── CASH MANAGEMENT ─────────────────────────────────────────────
model CashRegister {
  id              String             @id @default(cuid())
  locationId      String
  location        Location           @relation(fields: [locationId], references: [id])
  date            DateTime           @default(now())
  openingBalance  Float              @default(0)
  totalCashIn     Float              @default(0)
  totalCashOut    Float              @default(0)
  totalExpenses   Float              @default(0)
  expectedBalance Float              @default(0)
  actualBalance   Float?
  discrepancy     Float?
  status          CashRegisterStatus @default(OPEN)
  openedBy        String
  closedBy        String?
  closedAt        DateTime?
  transactions    CashTransaction[]
  handovers       CashHandover[]
  expenses        CashExpense[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([locationId, date])
}

enum CashRegisterStatus {
  OPEN
  CLOSED
  RECONCILED
  DISCREPANCY
}

model CashTransaction {
  id             String              @id @default(cuid())
  cashRegisterId String
  cashRegister   CashRegister        @relation(fields: [cashRegisterId], references: [id])
  orderId        String?
  type           CashTransactionType
  amount         Float
  staffId        String
  staffPin       String
  customerName   String?
  description    String?
  createdAt      DateTime            @default(now())
}

enum CashTransactionType {
  SALE
  CHANGE_GIVEN
  REFUND
  ADJUSTMENT
  EXPENSE
}

model CashHandover {
  id                  String       @id @default(cuid())
  cashRegisterId      String
  cashRegister        CashRegister @relation(fields: [cashRegisterId], references: [id])
  fromStaffId         String
  toStaffId           String
  amount              Float
  denomination        String?
  notes               String?
  confirmedByReceiver Boolean      @default(false)
  confirmedAt         DateTime?
  createdAt           DateTime     @default(now())
}

model CashExpense {
  id             String       @id @default(cuid())
  cashRegisterId String
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id])
  amount         Float
  reason         String
  staffId        String
  approvedBy     String?
  receiptUrl     String?
  createdAt      DateTime     @default(now())
}

// ── GALLERY ENHANCEMENTS (Pixieset-level) ───────────────────────
model DownloadLog {
  id        String   @id @default(cuid())
  galleryId String
  gallery   Gallery  @relation(fields: [galleryId], references: [id])
  photoId   String?
  type      String
  ipAddress String?
  createdAt DateTime @default(now())
}

model GalleryViewLog {
  id        String   @id @default(cuid())
  galleryId String
  gallery   Gallery  @relation(fields: [galleryId], references: [id])
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model PhotoSet {
  id        String   @id @default(cuid())
  galleryId String
  gallery   Gallery  @relation(fields: [galleryId], references: [id])
  name      String
  sortOrder Int      @default(0)
  photos    Photo[]
  createdAt DateTime @default(now())
}

// ── STORE / PRINT LAB ───────────────────────────────────────────
model PrintLabConfig {
  id            String             @id @default(cuid())
  name          String
  type          PrintLabType
  apiBaseUrl    String?
  apiKey        String?
  isActive      Boolean            @default(true)
  isDefault     Boolean            @default(false)
  markupPercent Float              @default(50)
  shippingRates Json?
  productMap    Json?
  fulfillments  FulfillmentOrder[]
  createdAt     DateTime           @default(now())
}

enum PrintLabType {
  LOCAL
  PRODIGI
  PRINTFUL
  GOOTEN
  CUSTOM_API
}

model FulfillmentOrder {
  id              String            @id @default(cuid())
  orderId         String
  order           Order             @relation(fields: [orderId], references: [id])
  printLabId      String
  printLab        PrintLabConfig    @relation(fields: [printLabId], references: [id])
  externalOrderId String?
  status          FulfillmentStatus @default(PENDING)
  trackingNumber  String?
  trackingUrl     String?
  shippingAddress Json
  items           Json
  costToUs        Float
  chargedCustomer Float
  profit          Float
  submittedAt     DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

enum FulfillmentStatus {
  PENDING
  SUBMITTED_TO_LAB
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  FAILED
  CANCELLED
}

model Coupon {
  id         String     @id @default(cuid())
  code       String     @unique
  type       CouponType
  value      Float
  minOrder   Float?
  maxUses    Int?
  usedCount  Int        @default(0)
  expiresAt  DateTime?
  isActive   Boolean    @default(true)
  locationId String?
  createdAt  DateTime   @default(now())
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum EditQuality {
  NONE
  LIGHT
  STANDARD
  PREMIUM
}

// ── LOCAL NETWORK / KIOSK CONFIG / SYNC ─────────────────────────
model KioskConfig {
  id            String       @id @default(cuid())
  name          String
  externalId    String       @unique
  type          KioskAppType
  locationId    String
  networkMode   NetworkMode  @default(ONLINE)
  serverIp      String? // for GALLERY_DISPLAY in LOCAL mode
  isLocalServer Boolean      @default(false) // true on the SALE_POINT serving locally
  lastSeenAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum KioskAppType {
  SALE_POINT
  GALLERY_DISPLAY
  TV_DISPLAY
  SD_UPLOAD
}

enum NetworkMode {
  ONLINE
  LOCAL
}

model SyncLog {
  id        String     @id @default(cuid())
  type      String // gallery | order | photo | cash | commission
  localId   String
  cloudId   String?
  status    SyncStatus @default(PENDING)
  error     String?
  syncedAt  DateTime?
  createdAt DateTime   @default(now())
}

enum SyncStatus {
  PENDING
  SYNCING
  SYNCED
  FAILED
}

model SyncQueue {
  id        String    @id @default(cuid())
  type      String
  action    String
  localId   String
  cloudId   String?
  payload   String
  status    String    @default("pending")
  attempts  Int       @default(0)
  lastError String?
  priority  Int       @default(5)
  createdAt DateTime  @default(now())
  syncedAt  DateTime?

  @@index([status])
  @@index([priority])
}

// ── GAMIFICATION ───────────────────────────────────────────────
model Badge {
  id          String      @id @default(cuid())
  key         String      @unique
  name        String
  description String
  icon        String
  category    String
  xpBonus     Int         @default(0)
  isSecret    Boolean     @default(false)
  earned      UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id])
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model XpLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  amount    Int
  context   String? // JSON
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model DailyChallenge {
  id         String   @id @default(cuid())
  date       DateTime
  locationId String?
  challenges String // JSON array of { title, target, xp, key }
  createdAt  DateTime @default(now())

  @@index([date])
}

// ── AI ─────────────────────────────────────────────────────────
model AIInsight {
  id          String   @id @default(cuid())
  type        String // performance | opportunity | alert | promotion | revenue
  targetType  String // photographer | location | system
  targetId    String
  title       String
  message     String
  priority    String   @default("medium") // high|medium|low
  actionable  Boolean  @default(true)
  actionTaken Boolean  @default(false)
  actionBy    String?
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([priority])
}

model SalesCoachTip {
  id        String  @id @default(cuid())
  trigger   String
  condition String // JSON
  message   String
  script    String?
  tactic    String // urgency|value|social_proof|bundle
  isActive  Boolean @default(true)
}

model AIBriefingLog {
  id        String   @id @default(cuid())
  scope     String // ceo | photographer | location
  scopeId   String?
  payload   String // JSON
  createdAt DateTime @default(now())
}

// ── AI PHOTOGRAPHY COACHING ─────────────────────────────────
model PoseCategory {
  id                 String   @id @default(cuid())
  name               String   @unique
  description        String
  subjectType        String
  difficulty         String
  tags               String
  exampleDescription String
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
}

model PhotoAnalysis {
  id             String @id @default(cuid())
  photoId        String @unique
  photo          Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  photographerId String
  photographer   User   @relation("PhotographerAnalyses", fields: [photographerId], references: [id])

  detectedPoseCategory String?
  poseConfidence       Float   @default(0)
  poseVariety          Boolean @default(false)

  subjectCount   Int     @default(1)
  subjectType    String?
  facesDetected  Int     @default(0)
  smilesDetected Int     @default(0)
  eyesOpen       Boolean @default(true)

  sharpnessScore   Int @default(50)
  exposureScore    Int @default(50)
  compositionScore Int @default(50)
  lightingScore    Int @default(50)
  framingScore     Int @default(50)

  emotionScore  Int @default(50)
  actionScore   Int @default(50)
  hookPotential Int @default(50)
  wowFactor     Int @default(50)

  technicalTotal Int @default(50)
  salesTotal     Int @default(50)
  overallScore   Int @default(50)

  improvements   String?
  poseSuggestion String?

  createdAt DateTime @default(now())

  @@index([photographerId, createdAt])
}

model PhotographerSkillProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation("UserSkillProfile", fields: [userId], references: [id], onDelete: Cascade)

  individualPoses Int @default(50)
  couplePoses     Int @default(50)
  familyPoses     Int @default(50)
  kidsPoses       Int @default(50)
  actionPoses     Int @default(50)
  portraitPoses   Int @default(50)

  avgSharpness   Int @default(50)
  avgExposure    Int @default(50)
  avgComposition Int @default(50)
  avgLighting    Int @default(50)
  avgFraming     Int @default(50)

  avgHookRate        Int @default(50)
  avgSalesConversion Int @default(50)
  avgEmotionCapture  Int @default(50)

  weakestPoseCategory String?
  weakestTechnical    String?
  strongestArea       String?

  trainingAssigned String?
  lastTrainingDate DateTime?
  improvementRate  Float     @default(0)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model TrainingAssignment {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation("UserTrainingAssignments", fields: [userId], references: [id], onDelete: Cascade)
  moduleId    String?
  module      AcademyModule? @relation(fields: [moduleId], references: [id])
  reason      String
  priority    String
  status      String         @default("assigned")
  assignedBy  String
  dueDate     DateTime?
  completedAt DateTime?
  skillBefore Int?
  skillAfter  Int?
  createdAt   DateTime       @default(now())

  @@index([userId, status])
}

model WeeklySkillReport {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation("UserWeeklyReports", fields: [userId], references: [id], onDelete: Cascade)
  weekStart       DateTime
  weekEnd         DateTime
  photosAnalyzed  Int       @default(0)
  avgOverallScore Int       @default(50)
  scoreChange     Int       @default(0)
  strengths       String?
  improvements    String?
  recommendations String?
  teamRank        Int?
  aboveAverage    String?
  belowAverage    String?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())

  @@index([userId, weekStart])
}

// ──────────────────────────────────────────────
// PIXEL ACADEMY MODELS
