enum WebsiteBlockType {
  HERO
  GALLERY_GRID
  TEXT
  ABOUT
  SERVICES
  TESTIMONIALS
  CONTACT_FORM
  CTA
  SPACER
  DIVIDER
  IMAGE
  VIDEO
  FAQ
