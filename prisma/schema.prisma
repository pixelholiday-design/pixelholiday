  helpfulNo   Int      @default(0)
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([slug])
}

model CSATSurvey {
  id           String   @id @default(cuid())
  userId       String?
  visitorEmail String?
  chatId       String?
  page         String?
  trigger      String
  score        Int
  feedback     String?
  npsScore     Int?
  createdAt    DateTime @default(now())

  @@index([trigger])
}

enum SupportChatStatus {
  ACTIVE
  WAITING_FOR_ADMIN
  ADMIN_REPLIED
  RESOLVED
  CLOSED
}

enum MessageSender {
  USER
  AI_BOT
  ADMIN
}

// ── VENUE APPLICATIONS ───────────────────────
