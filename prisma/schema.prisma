  @@index([organizationId])
}

model DestinationStaff {
  id            String      @id @default(cuid())
  userId        String
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id])
  role          String      @default("PHOTOGRAPHER")
  pin           String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())

  @@unique([userId, destinationId])
  @@index([destinationId])
  @@index([pin])
}

// ── MARKETPLACE-ONLY PROFILES ────────────────
model MarketplaceProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  displayName   String
  specialty     String
  city          String
  country       String
  bio           String?
  portfolioUrl  String?
  hourlyRate    Float?
  currency      String   @default("EUR")
  availableDays String?
  totalBookings Int      @default(0)
  averageRating Float?
  isActive      Boolean  @default(true)
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── CRM CLIENT MANAGEMENT ──────────────────────
model CrmClient {
  id             String             @id @default(cuid())
  orgId          String
  name           String
  email          String?
  phone          String?
  tags           String[]           @default([])
  notes          String?            @db.Text
  source         String? // "gallery", "manual", "inquiry", "booking"
  status         String             @default("ACTIVE") // LEAD, ACTIVE, VIP, ARCHIVED
  customerId     String? // Link to existing Customer if applicable
  totalSpent     Float              @default(0)
  sessionCount   Int                @default(0)
  lastContactAt  DateTime?
  communications CrmCommunication[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([orgId])
  @@index([email])
}

model CrmCommunication {
  id        String    @id @default(cuid())
  clientId  String
  client    CrmClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type      String // EMAIL, PHONE, NOTE, MEETING
  subject   String?
  content   String    @db.Text
  createdAt DateTime  @default(now())

  @@index([clientId])
}

// ── INVOICING ─────────────────────────────────
model Invoice {
  id                String        @id @default(cuid())
  invoiceNumber     String        @unique
  orgId             String
  clientName        String
  clientEmail       String
  clientAddress     String?
  items             InvoiceItem[]
  subtotal          Float
  taxRate           Float         @default(0)
  taxAmount         Float         @default(0)
  total             Float
  currency          String        @default("EUR")
  status            InvoiceStatus @default(DRAFT)
  dueDate           DateTime
  paidAt            DateTime?
  paidAmount        Float?
  paymentMethod     String?
  stripePaymentLink String?
  notes             String?       @db.Text
  sentAt            DateTime?
  viewedAt          DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([orgId])
  @@index([status])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int     @default(1)
  unitPrice   Float
  total       Float

  @@index([invoiceId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

// ── MINI SESSIONS ─────────────────────────────
model MiniSession {
  id           String               @id @default(cuid())
  orgId        String
  title        String
  description  String?              @db.Text
  date         DateTime
  startTime    String
  endTime      String
  slotDuration Int                  @default(15)
  maxSlots     Int
  bookedSlots  Int                  @default(0)
  price        Float
  currency     String               @default("EUR")
  location     String?
  coverImage   String?
  isPublished  Boolean              @default(false)
  slug         String               @unique
  bookings     MiniSessionBooking[]
  createdAt    DateTime             @default(now())
}

model MiniSessionBooking {
  id          String      @id @default(cuid())
  sessionId   String
  session     MiniSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  slotTime    String
  clientName  String
  clientEmail String
  clientPhone String?
  isPaid      Boolean     @default(false)
  createdAt   DateTime    @default(now())

  @@index([sessionId])
}

// ── PROJECT MANAGEMENT ────────────────────────
model Project {
  id         String    @id @default(cuid())
  orgId      String
  clientId   String?
  title      String
  status     String    @default("INQUIRY") // INQUIRY, BOOKED, SHOT, EDITING, DELIVERED, ARCHIVED
  eventDate  DateTime?
  eventType  String?
  notes      String?   @db.Text
  galleryId  String?
  contractId String?
  invoiceId  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([orgId, status])
}

// ── PRICING TIERS ─────────────────────────────
model PricingTier {
  id           String @id @default(cuid())
  priceSheetId String
  minQuantity  Int
  maxQuantity  Int?
  pricePerUnit Float

  @@index([priceSheetId])
}

// ── ALBUM DESIGNER ────────────────────────────
model Album {
  id         String        @id @default(cuid())
  orgId      String
  name       String
  spreads    AlbumSpread[]
  template   String        @default("classic")
  status     String        @default("DRAFT") // DRAFT, READY, ORDERED
  labOrderId String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model AlbumSpread {
  id       String @id @default(cuid())
  albumId  String
  album    Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  layout   String // "single", "two-column", "three-up", "full-bleed"
  photoIds String // JSON array of photo IDs
  order    Int
}

// ── PHOTO BOOK DESIGNER ──────────────────────
model PhotoBookDesign {
  id            String   @id @default(cuid())
  galleryId     String?
  customerEmail String?
  customerName  String?
  title         String   @default("My Photo Book")
  bookType      String   @default("HARDCOVER")
  bookSize      String   @default("8x11")
  paper         String   @default("MATTE")
  pageCount     Int      @default(20)
  pages         Json     @default("[]")
  coverDesign   Json?
  status        String   @default("DRAFT")
  orderId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ClientAccount {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  email          String
  passwordHash   String?
  phone          String?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId])
}

// ── FOTIQO AI AGENT ──────────────────────────
model AgentConversation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation("OrgAgentConversations", fields: [organizationId], references: [id])
  userId         String
  user           User         @relation("UserAgentConversations", fields: [userId], references: [id])
  messages       Json         @default("[]")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([userId])
}

model AgentTask {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation("OrgAgentTasks", fields: [organizationId], references: [id])
  type           String
  status         String       @default("SUGGESTED")
  title          String
  description    String?
  data           Json?
  scheduledFor   DateTime?
  executedAt     DateTime?
  result         Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([status])
}

model AgentSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation("OrgAgentSettings", fields: [organizationId], references: [id])
  isEnabled      Boolean      @default(true)
  autoPost       Boolean      @default(false)
  autoReply      Boolean      @default(false)
  autoEnhance    Boolean      @default(false)
  dailyBriefing  Boolean      @default(true)
  weeklyReport   Boolean      @default(true)
  socialAccounts Json?
  brandVoice     String?
  targetAudience String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ── VENUE COMPANY TEAM MANAGEMENT ─────────────────────────

model StaffProfile {
  id                   String                  @id @default(cuid())
  userId               String                  @unique
  user                 User                    @relation("UserStaffProfile", fields: [userId], references: [id])
  companyId            String
  designation          String // CEO, Operations Manager, Supervisor, Lead Photographer, etc.
  department           String? // Operations, Photography, Sales, Administration
  level                String // C_LEVEL, MANAGEMENT, SENIOR, STAFF, JUNIOR, TRAINEE
  employmentType       String                  @default("FULL_TIME") // FULL_TIME, PART_TIME, SEASONAL, CONTRACT
  startDate            DateTime                @default(now())
  endDate              DateTime?
  isActive             Boolean                 @default(true)
  reportsToId          String?
  reportsTo            StaffProfile?           @relation("ReportsTo", fields: [reportsToId], references: [id])
  directReports        StaffProfile[]          @relation("ReportsTo")
  assignedDestinations Json?
  primaryDestinationId String?
  salaryType           String                  @default("MONTHLY") // MONTHLY, DAILY, HOURLY, COMMISSION_ONLY
  salaryAmount         Float?
  salaryCurrency       String                  @default("EUR")
  commissionRate       Float?
  bonusTarget          Float?
  dateOfBirth          DateTime?
  nationality          String?
  languages            Json?
  phone                String?
  emergencyContact     String?
  emergencyPhone       String?
  address              String?
  photoUrl             String?
  cvUrl                String?
  contractUrl          String?
  idDocumentUrl        String?
  workPermitUrl        String?
  workPermitExpiry     DateTime?
  skills               Json?
  certifications       Json?
  equipmentTrained     Json?
  performanceScore     Float?
  lastReviewDate       DateTime?
  nextReviewDate       DateTime?
  needsTraining        Boolean                 @default(false)
  needsCoaching        Boolean                 @default(false)
  needsReplacement     Boolean                 @default(false)
  onProbation          Boolean                 @default(false)
  isTopPerformer       Boolean                 @default(false)
  managerNotes         String?
  hrNotes              String?
  performanceReviews   PerformanceReview[]     @relation("StaffPerformanceReviews")
  trainingRecords      TrainingRecord[]        @relation("StaffTrainingRecords")
  staffCommissions     StaffCommissionConfig[] @relation("StaffCommissionConfigs")
  staffBonuses         StaffBonusTarget[]      @relation("StaffBonusTargets")
  staffPayouts         StaffPayout[]           @relation("StaffPayouts")
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@index([companyId])
  @@index([reportsToId])
}

model PerformanceReview {
  id               String       @id @default(cuid())
  staffProfileId   String
  staffProfile     StaffProfile @relation("StaffPerformanceReviews", fields: [staffProfileId], references: [id])
  reviewerId       String
  companyId        String
  period           String
  photoQuality     Float?
  salesPerformance Float?
  customerService  Float?
  punctuality      Float?
  teamwork         Float?
  initiative       Float?
  appearance       Float?
  technicalSkills  Float?
  overallScore     Float
  photosUploaded   Int?
  salesAmount      Float?
  salesConversion  Float?
  avgGalleryRating Float?
  shiftsCompleted  Int?
  shiftsAbsent     Int?
  lateArrivals     Int?
  strengths        String?
  improvements     String?
  goals            String?
  actionPlan       String?
  recommendation   String // PROMOTE, RETAIN, TRAIN, COACH, PROBATION, TERMINATE
  staffSigned      Boolean      @default(false)
  staffSignedAt    DateTime?
  managerSigned    Boolean      @default(false)
  managerSignedAt  DateTime?
  createdAt        DateTime     @default(now())

  @@index([companyId])
  @@index([staffProfileId])
}

model TrainingRecord {
  id             String       @id @default(cuid())
  staffProfileId String
  staffProfile   StaffProfile @relation("StaffTrainingRecords", fields: [staffProfileId], references: [id])
  companyId      String
  trainingType   String // ONBOARDING, PHOTOGRAPHY, SALES, KIOSK, SAFETY, CUSTOMER_SERVICE, EQUIPMENT, SOFTWARE
  title          String
  description    String?
  status         String       @default("ASSIGNED") // ASSIGNED, IN_PROGRESS, COMPLETED, FAILED
  dueDate        DateTime?
  completedDate  DateTime?
  score          Float?
  certificateUrl String?
  createdAt      DateTime     @default(now())

  @@index([companyId])
  @@index([staffProfileId])
}

model StaffCommissionConfig {
  id             String       @id @default(cuid())
  staffProfileId String
  staffProfile   StaffProfile @relation("StaffCommissionConfigs", fields: [staffProfileId], references: [id])
  companyId      String
  isEnabled      Boolean      @default(true)
  commissionType String // PHOTO_SALES, KIOSK_SALES, DESTINATION_REVENUE, REGION_REVENUE, FIXED_PER_SALE
  commissionRate Float?
  fixedPerSale   Float?
  monthlyCap     Float?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([companyId])
  @@index([staffProfileId])
}

model StaffBonusTarget {
  id             String       @id @default(cuid())
  staffProfileId String
  staffProfile   StaffProfile @relation("StaffBonusTargets", fields: [staffProfileId], references: [id])
  companyId      String
  period         String       @default("MONTHLY") // MONTHLY, QUARTERLY
  metricType     String // REVENUE, CONVERSION_RATE, PHOTO_COUNT, CUSTOMER_RATING, SHIFTS_COMPLETED
  targetValue    Float
  bonusAmount    Float
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([companyId])
  @@index([staffProfileId])
}

model StaffPayout {
  id               String       @id @default(cuid())
  staffProfileId   String
  staffProfile     StaffProfile @relation("StaffPayouts", fields: [staffProfileId], references: [id])
  companyId        String
  period           String
  baseSalary       Float
  commissionEarned Float
  bonusEarned      Float
  deductions       Float        @default(0)
  totalPayout      Float
  status           String       @default("PENDING") // PENDING, APPROVED, PAID
  paidAt           DateTime?
  notes            String?
  createdAt        DateTime     @default(now())

  @@index([companyId])
  @@index([staffProfileId])
}

// ── PROFESSIONAL EMAIL SYSTEM ─────────────────

model FotiqoEmail {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("UserFotiqoEmails", fields: [userId], references: [id])
  organizationId  String?

  emailAddress    String   @unique // sarah.wilson@fotiqo.com
  emailType       String   @default("PERSONAL") // PERSONAL (SaaS photographer), COMPANY (venue staff)
  subdomain       String?  // null = @fotiqo.com, "pixelholiday" = @pixelholiday.fotiqo.com
  isActive        Boolean  @default(true)
  isPrimary       Boolean  @default(true)

  messages        EmailMessage[] @relation("EmailAccountMessages")
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([organizationId])
}

model EmailMessage {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("UserEmailMessages", fields: [userId], references: [id])
  fotiqoEmailId   String
  fotiqoEmail     FotiqoEmail @relation("EmailAccountMessages", fields: [fotiqoEmailId], references: [id])

  direction       String   // INBOUND, OUTBOUND
  fromAddress     String
  fromName        String?
  toAddress       String
  toName          String?
  ccAddresses     Json?
  subject         String
  bodyHtml        String?  @db.Text
  bodyText        String?  @db.Text
  attachments     Json?

  isRead          Boolean  @default(false)
  isStarred       Boolean  @default(false)
  isArchived      Boolean  @default(false)
  isDeleted       Boolean  @default(false)
  isDraft         Boolean  @default(false)

  folder          String   @default("INBOX") // INBOX, SENT, DRAFTS, ARCHIVE, TRASH
  labels          Json?

  aiSummary       String?
  aiSuggestedReply String? @db.Text
  aiCategory      String?  // BOOKING_INQUIRY, CLIENT_FOLLOWUP, PARTNERSHIP, INVOICE, PERSONAL, SPAM

  threadId        String?
  inReplyTo       String?

  receivedAt      DateTime @default(now())
  sentAt          DateTime?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([fotiqoEmailId])
  @@index([folder])
  @@index([threadId])
  @@index([isRead])
}

model EmailSignature {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation("UserEmailSignature", fields: [userId], references: [id])
  organizationId  String?

  style           String   @default("MINIMAL") // MINIMAL, WITH_LOGO, WITH_PHOTO, COMPANY_BRANDED
  displayName     String
  title           String?
  company         String?
  phone           String?
  email           String?
  websiteUrl      String?
  bookingUrl      String?
  location        String?
  logoUrl         String?
  photoUrl        String?
  socialInstagram String?
  socialFacebook  String?
  socialLinkedin  String?
  socialTiktok    String?
  brandColor      String?  @default("#0EA5A5")
  showPoweredBy   Boolean  @default(true)
  signatureHtml   String?  @db.Text

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
}
